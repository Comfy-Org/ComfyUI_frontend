  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@iconify-json/lucide": "catalog:",
    "@iconify/tailwind4": "catalog:",
    "@iconify/tools": "catalog:",
    "@iconify/utils": "catalog:",
    "tailwindcss-primeui": "catalog:",
    "tw-animate-css": "catalog:"
  },
  "devDependencies": {
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
