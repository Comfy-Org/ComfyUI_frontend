{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["../../src/*"]
    }
  },
  "include": [
    "../../src/extension-api/**/*.ts"
  ],
  "exclude": [
    "../../src/**/*.test.ts",
    "../../src/**/*.spec.ts",
    "../../src/**/*.vue"
  ]
}
