{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./src/*"],
      "@frontend-locales/*": ["../../src/locales/*"]
    },
    "types": [
      "vite/client",
      "node",
      "vitest/globals",
      "@webgpu/types",
      "@testing-library/jest-dom/vitest"
    ]
  },
  "include": [
    ".storybook/**/*",
    "src/**/*.ts",
    "src/**/*.vue",
    "src/**/*.d.ts",
    "vite.config.mts",
    "vitest.config.mts"
  ],
  "references": []
}
