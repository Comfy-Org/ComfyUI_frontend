{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*",
    "e2e/**/*",
    "scripts/**/*",
    "astro.config.ts",
    "playwright.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["src/**/*.stories.ts"],
  "references": [{ "path": "./tsconfig.stories.json" }]
}
