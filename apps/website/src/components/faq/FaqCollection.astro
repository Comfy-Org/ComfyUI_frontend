---
import { getCollection, render } from 'astro:content'

import type { Locale, TranslationKey } from '../../i18n/translations'
import { t } from '../../i18n/translations'
import FaqLink from './FaqLink.astro'

interface Props {
  prefix: string
  headingKey: TranslationKey
  locale?: Locale
}

const { prefix, headingKey, locale = 'en' } = Astro.props

const entries = await getCollection('faq', (entry) =>
  entry.id.startsWith(`${prefix}/${locale}/`)
)
entries.sort((a, b) => a.data.order - b.data.order)

const items = await Promise.all(
  entries.map(async (entry) => ({
    id: entry.id,
    question: entry.data.question,
    Content: (await render(entry)).Content
  }))
)
---

<section id="faq" class="max-w-9xl mx-auto px-4 py-16 lg:px-20 lg:py-24">
  <div class="flex flex-col gap-6 md:flex-row md:gap-16">
    <div
      class="sticky top-20 z-10 w-full shrink-0 self-start bg-primary-comfy-ink py-4 md:top-28 md:w-80 md:py-0"
    >
      <h2 class="text-4xl font-light text-primary-comfy-canvas md:text-5xl">
        {t(headingKey, locale)}
      </h2>
    </div>

    <div class="flex-1">
      {
        items.map(({ id, question, Content }) => (
          <details
            id={`faq-${id}`}
            class="group border-primary-comfy-canvas/10 border-b"
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left text-base font-light text-primary-comfy-canvas [&::-webkit-details-marker]:hidden">
              {question}
              <svg
                class="size-5 shrink-0 transition-transform duration-200 group-open:rotate-180"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <path
                  d="m6 9 6 6 6-6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </summary>
            <div class="faq-answer pb-5 text-sm wrap-break-word text-primary-comfy-canvas/70">
              <Content components={{ a: FaqLink }} />
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq-answer :global(p) {
    margin: 0 0 0.75rem;
  }
  .faq-answer :global(p:last-child) {
    margin-bottom: 0;
  }
  .faq-answer :global(ul) {
    margin: 0 0 0.75rem;
    padding-left: 1.25rem;
    list-style: disc;
  }
  .faq-answer :global(ul:last-child) {
    margin-bottom: 0;
  }
  .faq-answer :global(li) {
    margin: 0 0 0.25rem;
  }
  .faq-answer :global(a) {
    color: var(--color-primary-comfy-yellow);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.15s;
  }
  .faq-answer :global(a:hover) {
    opacity: 0.7;
  }
</style>
