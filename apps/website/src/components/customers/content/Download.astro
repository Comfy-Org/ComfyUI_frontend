---
interface Props {
  href: string
  label: string
  newTab?: boolean
}

const { href, label, newTab = false } = Astro.props
---

<a
  href={href}
  download={newTab ? undefined : true}
  target={newTab ? '_blank' : undefined}
  rel={newTab ? 'noopener noreferrer' : undefined}
  class="border-primary-comfy-yellow text-primary-comfy-yellow hover:text-primary-comfy-ink hover:bg-primary-comfy-yellow my-6 inline-flex items-center gap-2 rounded-full border px-5 py-2.5 text-sm font-semibold transition-colors"
>
  <svg
    class="size-4"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
    <polyline points="7 10 12 15 17 10"></polyline>
    <line x1="12" y1="15" x2="12" y2="3"></line>
  </svg>
  {label}
</a>
