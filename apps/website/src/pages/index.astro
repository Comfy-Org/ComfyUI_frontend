---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCardsSection from "../components/home/ProductCardsSection.vue";
import HeroSection from "../components/home/HeroSection.vue";
import SocialProofBarSection from "../components/common/SocialProofBarSection.vue";
import ProductShowcaseSection from "../components/home/ProductShowcaseSection.vue";
import UseCaseSection from "../components/home/UseCaseSection.vue";
import CaseStudySpotlightSection from "../components/home/CaseStudySpotlightSection.vue";
import GetStartedSection from "../components/home/GetStartedSection.vue";
import BuildWhatSection from "../components/home/BuildWhatSection.vue";
import { t } from "../i18n/translations";
import { externalLinks } from "../config/routes";
import {
  buildPageGraph,
  pageContext,
  softwareApplicationNode,
  softwareSourceCodeNode,
} from "../utils/jsonLd";

const title = "Comfy — Professional Control of Visual AI";
const description = t("hero.subtitle", "en");
const { siteUrl, locale, url } = pageContext(
  Astro.site,
  Astro.url.pathname,
  Astro.currentLocale,
);
const jsonLd = buildPageGraph(
  { siteUrl, locale },
  { url, name: title, description },
  softwareApplicationNode({
    siteUrl,
    id: `${siteUrl}/#software`,
    name: "ComfyUI",
    url: siteUrl,
    firstParty: true,
    applicationCategory: "MultimediaApplication",
    operatingSystem: "Windows, macOS, Linux",
    description,
    isFree: true,
  }),
  softwareSourceCodeNode({
    siteUrl,
    id: `${siteUrl}/#sourcecode`,
    name: "ComfyUI",
    codeRepository: externalLinks.github,
    programmingLanguage: "Python",
  }),
);
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={jsonLd}
  keywords={[
    "comfyui app",
    "comfyui web app",
    "comfy ui application",
    "comfyui application",
    "comfy app",
    "comfyui",
    "visual ai app",
    "node-based ai",
    "generative ai workflows",
  ]}
>
  <HeroSection client:load />
  <SocialProofBarSection />
  <ProductShowcaseSection client:load />
  <UseCaseSection client:load />
  <GetStartedSection />
  <ProductCardsSection />
  <CaseStudySpotlightSection client:load />
  <BuildWhatSection />
</BaseLayout>
