      </div>
      <p class="text-[15px] tracking-[0.02em] opacity-90">
        Looks like this node went off-grid.
      </p>
      <p
        class="font-mono text-sm tracking-[0.05em] opacity-75"
        >Score: <span id="scoreNow">0</span><span
          class="mx-2.5 opacity-50">|</span
        >Best: <span id="scoreBest">0</span></p
      >
    </div>
    <div class="relative flex min-h-0 flex-1 items-center justify-center overflow-hidden">
      <svg
        id="game"
        class="block size-full"
        xmlns="http://www.w3.org/2000/svg"
        preserveAspectRatio="xMidYMid meet">
        <g id="board"></g>
        <g
          fill="currentColor"
          class="text-secondary-mauve"
          transform="matrix(0.9346 -0.02737 -0.00901 1.0422 -597.31 -135.88)">
          <text
            id="startCta"
            x="300"
            y="200"
            font-family="'PP Formula', sans-serif"
            font-size="32"
            letter-spacing="0.15em"
            text-anchor="end"
            dominant-baseline="middle"
            transform="rotate(-31 400 200)"
            class="cursor-pointer uppercase"
            >CLICK TO START</text
          >
        </g>
      </svg>

      <div
        class="absolute inset-0 z-2 hidden items-center justify-center rounded-lg bg-primary-comfy-ink/85"
        id="pauseOverlay">
        <div
          class="rounded-lg border border-primary-comfy-plum bg-primary-comfy-ink px-12 py-8 text-center">
          <h2 class="mb-2 text-xl tracking-widest text-primary-comfy-yellow">
            PAUSED
          </h2>
          <p class="my-1 text-xs tracking-widest text-primary-comfy-canvas">
            Press space to resume
          </p>
        </div>
      </div>
    </div>
  </div>

  <script>
    import '../scripts/snakeGame'
  </script>
