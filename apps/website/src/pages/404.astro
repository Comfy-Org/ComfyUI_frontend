---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="404 — Page Not Found — Comfy"
  noindex>
  <div
    class="grid w-full grid-rows-1 place-items-center p-4 h-[calc(100dvh-12rem)]">
    <div
      class="relative flex size-full min-h-0 items-center justify-center overflow-hidden">
      <svg
        id="game"
        class="block size-full"
        xmlns="http://www.w3.org/2000/svg"
        preserveAspectRatio="xMidYMid meet">
        <use
          class="pointer-events-none text-secondary-mauve"
          href="/svg/404-title.svg#title404"
        ></use>
        <g id="board"></g>
      </svg>

      <div
        class="absolute inset-0 z-2 hidden items-center justify-center rounded-lg bg-primary-comfy-ink/85"
        id="overlay">
        <div
          class="rounded-lg border border-primary-comfy-plum bg-primary-comfy-ink px-12 py-8 text-center">
          <h2
            class="mb-2 text-xl tracking-widest text-primary-comfy-yellow empty:hidden"
            id="ovTitle">
          </h2>
          <p
            class="my-1 text-xs tracking-widest text-primary-comfy-canvas"
            id="ovMsg">
          </p>
          <button
            class="mt-4 cursor-pointer rounded border-none bg-primary-comfy-plum px-5 py-2.5 font-inherit text-xs uppercase tracking-widest text-primary-comfy-canvas hover:bg-primary-comfy-yellow hover:text-primary-comfy-ink"
            id="ovBtn"
            >START</button
          >
        </div>
      </div>

      <div
        class="absolute inset-0 z-2 hidden items-center justify-center rounded-lg bg-primary-comfy-ink/85"
        id="pauseOverlay">
        <div
          class="rounded-lg border border-primary-comfy-plum bg-primary-comfy-ink px-12 py-8 text-center">
          <h2 class="mb-2 text-xl tracking-widest text-primary-comfy-yellow">
            PAUSED
          </h2>
          <p class="my-1 text-xs tracking-widest text-primary-comfy-canvas">
            Press space to resume
          </p>
        </div>
      </div>
    </div>
  </div>

  <script>
    import '../scripts/snakeGame'
  </script>
</BaseLayout>
