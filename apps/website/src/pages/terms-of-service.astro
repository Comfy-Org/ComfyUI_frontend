        <!-- Full legal text to be added -->
      </div>

      <!-- 3. Using the Services -->
      <div>
        <h2 class="text-xl font-semibold text-white">3. Using the Services</h2>
        <p class="mt-4 text-sm leading-relaxed text-smoke-700">
