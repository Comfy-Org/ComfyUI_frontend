---
import BaseLayout from '../layouts/BaseLayout.astro'
import HeroSection from '../components/product/local/HeroSection.vue'
import CloudBannerSection from '../components/product/shared/CloudBannerSection.vue'
import AIModelsSection from '../components/product/shared/AIModelsSection.vue'
import ReasonSection from '../components/product/local/ReasonSection.vue'
import EcoSystemSection from '../components/product/local/EcoSystemSection.vue'
import ProductCardsSection from '../components/product/local/ProductCardsSection.vue'
import FAQSection from '../components/product/local/FAQSection.vue'
import { t } from '../i18n/translations'
import {
  buildPageGraph,
  pageContext,
  softwareApplicationNode,
} from '../utils/jsonLd'

const title = 'Download Comfy Desktop — Run AI on Your Hardware'
const description = t('download.hero.subtitle', 'en')
const { siteUrl, locale, url } = pageContext(
  Astro.site,
  Astro.url.pathname,
  Astro.currentLocale,
)
// The download page's primary entity is the ComfyUI desktop app itself, the
// same first-party #software entity the home page describes.
const jsonLd = buildPageGraph(
  { siteUrl, locale },
  { url, name: title, description, mainEntityId: `${siteUrl}/#software` },
  softwareApplicationNode({
    siteUrl,
    id: `${siteUrl}/#software`,
    name: 'ComfyUI',
    url: siteUrl,
    firstParty: true,
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Windows, macOS, Linux',
    description,
    isFree: true,
  }),
)
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={jsonLd}
  keywords={['comfyui app', 'comfyui desktop app', 'comfyui desktop', 'comfy ui application', 'comfyui download', 'download comfyui', 'comfyui windows', 'comfyui mac', 'comfyui linux']}
>
  <CloudBannerSection />
  <HeroSection client:load />
  <ReasonSection />
  <EcoSystemSection client:visible />
  <AIModelsSection />
  <ProductCardsSection />
  <FAQSection client:visible />
</BaseLayout>
