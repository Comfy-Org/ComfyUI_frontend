---
import BaseLayout from '../layouts/BaseLayout.astro'
import HeroSection from '../components/about/HeroSection.vue'
import StorySection from '../components/about/StorySection.vue'
import OurValuesSection from '../components/about/OurValuesSection.vue'
import ValuesSection from '../components/about/ValuesSection.vue'
import CareersSection from '../components/about/CareersSection.vue'
import { t } from '../i18n/translations'
import {
  absoluteUrl,
  buildPageGraph,
  organizationId,
  pageContext,
} from '../utils/jsonLd'

const title = 'About Us — Comfy'
const { siteUrl, locale, url } = pageContext(
  Astro.site,
  Astro.url.pathname,
  Astro.currentLocale,
)
const jsonLd = buildPageGraph(
  { siteUrl, locale },
  {
    url,
    name: title,
    type: 'AboutPage',
    mainEntityId: organizationId(siteUrl),
    crumbs: [
      { name: t('breadcrumb.home', locale), url: absoluteUrl(Astro.site, '/') },
      { name: 'About Us' },
    ],
  },
)
---

<BaseLayout title={title} jsonLd={jsonLd}>
  <HeroSection client:load />
  <StorySection />
  <OurValuesSection />
  <ValuesSection client:visible />
  <CareersSection />
</BaseLayout>
