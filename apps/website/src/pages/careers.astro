---
import BaseLayout from '../layouts/BaseLayout.astro'
import HeroSection from '../components/careers/HeroSection.vue'
import RolesSection from '../components/careers/RolesSection.vue'
import WhyJoinSection from '../components/careers/WhyJoinSection.vue'
import TeamPhotosSection from '../components/careers/TeamPhotosSection.vue'
import FAQSection from '../components/common/FAQSection.vue'
import { fetchRolesForBuild } from '../utils/ashby'
import { reportAshbyOutcome } from '../utils/ashby.ci'
import { t } from '../i18n/translations'
import {
  absoluteUrl,
  buildPageGraph,
  itemListNode,
  pageContext,
} from '../utils/jsonLd'

const outcome = await fetchRolesForBuild()
reportAshbyOutcome(outcome)

if (outcome.status === 'failed') {
  throw new Error(
    `Ashby fetch failed and no snapshot is available. Reason: ${outcome.reason}. ` +
      'Run `pnpm --filter @comfyorg/website ashby:refresh-snapshot` locally and commit the snapshot.'
  )
}

const departments = outcome.snapshot.departments

const title = 'Careers — Comfy'
const { siteUrl, locale, url } = pageContext(
  Astro.site,
  Astro.url.pathname,
  Astro.currentLocale,
)
const listId = `${url}#itemlist`
const jsonLd = buildPageGraph(
  { siteUrl, locale },
  {
    url,
    name: title,
    type: 'CollectionPage',
    mainEntityId: listId,
    crumbs: [
      { name: t('breadcrumb.home', locale), url: absoluteUrl(Astro.site, '/') },
      { name: 'Careers' },
    ],
  },
  itemListNode(
    url,
    departments.flatMap((department) =>
      department.roles.map((role) => ({ name: role.title, url: role.jobUrl })),
    ),
  ),
)
---

<BaseLayout title={title} description="Join the team building the operating system for generative AI. Open roles in engineering, design, marketing, and more." jsonLd={jsonLd}>
  <HeroSection />
  <RolesSection departments={departments} client:visible />
  <WhyJoinSection client:visible />
  <TeamPhotosSection client:visible />
  <FAQSection
    headingKey="careers.faq.heading"
    faqPrefix="careers.faq"
    faqCount={8}
    client:visible
  />
</BaseLayout>
