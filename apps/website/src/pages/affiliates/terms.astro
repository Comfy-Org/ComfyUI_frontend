---
import BaseLayout from '../../layouts/BaseLayout.astro'
import HeroSection from '../../components/legal/HeroSection.vue'
import LegalContentSection from '../../components/legal/LegalContentSection.vue'
import type { Locale } from '../../i18n/translations'
import { t } from '../../i18n/translations'

const rawLocale = Astro.currentLocale ?? 'en'
const locale: Locale = rawLocale === 'zh-CN' ? 'zh-CN' : 'en'
---

<BaseLayout
  title={t('affiliate-terms.page.title', locale)}
  description={t('affiliate-terms.page.description', locale)}
  noindex
>
  <HeroSection title={t('affiliate-terms.page.heading', locale)} />
  <LegalContentSection
    prefix="affiliate-terms"
    locale={locale}
    effectiveDateKey="affiliate-terms.effective-date"
    effectiveDateLabelKey="affiliate-terms.page.effectiveDateLabel"
    tocLabelKey="affiliate-terms.page.tocLabel"
    client:load
  />
</BaseLayout>
