---
// Shared body for /events in every locale: the locale-specific page files are
// thin wrappers so meta, breadcrumbs, and JSON-LD stay defined once. Locale
// comes from the rendering page's URL. Mirrors LearningDirectoryPage.astro:
// CollectionPage + ItemList of the event detail pages, plus an Event node per
// dated upcoming event.
import BaseLayout from '../../layouts/BaseLayout.astro'
import EventsHeroSection from './EventsHeroSection.vue'
import PastEventsSection from './PastEventsSection.vue'
import UpcomingEventsSection from './UpcomingEventsSection.vue'
import { localizeHref } from '../../config/routes'
import {
  pastEventPath,
  upcomingEvents,
  watchablePastEvents
} from '../../data/events'
import { t } from '../../i18n/translations'
import type { JsonLdNode } from '../../utils/jsonLd'
import {
  absoluteUrl,
  eventNode,
  itemListNode,
  jsonLdId,
  pageContext
} from '../../utils/jsonLd'

const { siteUrl, locale, url } = pageContext(
  Astro.site,
  Astro.url.pathname,
  Astro.currentLocale
)

const eventList = itemListNode(
  url,
  t('events.past.title', locale),
  watchablePastEvents.map((event) => ({
    name: event.title[locale],
    url: absoluteUrl(Astro.site, localizeHref(pastEventPath(event), locale))
  }))
)

// Event rich results need a startDate, so undated placeholders are skipped.
// The location copy doubles as the online/physical discriminator.
const upcomingEventNodes: JsonLdNode[] = upcomingEvents
  .filter((event) => event.dateTime)
  .map((event) => {
    const href = event.link.href[locale]
    const online = event.location.en === 'Online'
    return eventNode({
      siteUrl,
      id: jsonLdId(url, `event-${event.id}`),
      name: event.name[locale],
      description: event.description[locale],
      startDate: event.dateTime!,
      ...(online
        ? {
            virtualUrl: href.startsWith('/')
              ? absoluteUrl(Astro.site, href)
              : href
          }
        : { placeName: event.location[locale] }),
      locale
    })
  })

const breadcrumbs = [
  {
    name: t('breadcrumb.home', locale),
    url: absoluteUrl(Astro.site, localizeHref('/', locale))
  },
  { name: t('breadcrumb.events', locale) }
]
---

<BaseLayout
  title={t('events.page.title', locale)}
  description={t('events.page.description', locale)}
  pageType="CollectionPage"
  mainEntityId={jsonLdId(url, 'itemlist')}
  breadcrumbs={breadcrumbs}
  extraJsonLd={[eventList, ...upcomingEventNodes]}
>
  <EventsHeroSection locale={locale} client:load />
  <UpcomingEventsSection locale={locale} />
  <PastEventsSection locale={locale} client:visible />
</BaseLayout>
